---
// 订阅条（深绿色），首页和文章页都用。
// 已接 Buttondown：表单 POST 到「公开 embed 端点」——这个端点无需密钥、只能投递订阅，
// 所以贴在静态站前端是安全的（区别于需要密钥、绝不能放前端的后台 API）。
const { heading = '两周一封慢读信', text = '德语、故事、AI —— 想清楚后才寄出的一篇长文。' } = Astro.props;

// 把用户名抽成常量，换号/换服务只改这一处（不写死、可扩展）。
const BUTTONDOWN_USER = 'justinzyc271828';
const action = `https://buttondown.com/api/emails/embed-subscribe/${BUTTONDOWN_USER}`;
---

<section class="subscribe">
  <div class="glow"></div>
  <div class="left">
    <span class="ic">~</span>
    <div>
      <div class="h">{heading}</div>
      <div class="p">{text}</div>
    </div>
  </div>

  <!-- 真表单：提交后在小弹窗里打开 Buttondown 确认页，访客不离开本站 -->
  <form
    class="form"
    action={action}
    method="post"
    target="popupwindow"
    onsubmit={`window.open('https://buttondown.com/${BUTTONDOWN_USER}', 'popupwindow')`}
  >
    <input class="email" type="email" name="email" placeholder="输入你的邮箱" required aria-label="邮箱地址" />
    <input type="hidden" name="embed" value="1" />
    <button class="go" type="submit">订阅</button>
  </form>
</section>
