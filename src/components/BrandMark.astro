---
// 站点标记：洞口透光 + 齿轮（哲学 × AI）。Header / Footer 复用，favicon 同款。
const { class: className = '' } = Astro.props;
---
<svg class={className} viewBox="0 0 100 100" aria-label="Grenzgang">
  <rect width="100" height="100" rx="22" fill="#20283a" />
  <line x1="27" y1="80" x2="73" y2="80" stroke="#f3ead6" stroke-width="5" stroke-linecap="round" />
  <path d="M27 80 L27 55 C27 34 44 27 49 26" fill="none" stroke="#f3ead6" stroke-width="5" stroke-linecap="round" />
  <path d="M73 80 L73 55 C73 34 56 27 51 26" fill="none" stroke="#f3ead6" stroke-width="5" stroke-linecap="round" />
  <path d="M50 30 L45.5 58" stroke="#e9b44a" stroke-width="2.4" stroke-linecap="round" />
  <path d="M50 30 L54.5 58" stroke="#e9b44a" stroke-width="2.4" stroke-linecap="round" />
  <g transform="translate(50 63)">
    <g fill="#e9b44a">
      <rect x="-2.6" y="-13.2" width="5.2" height="6" rx="1.2" />
      <rect x="-2.6" y="-13.2" width="5.2" height="6" rx="1.2" transform="rotate(45)" />
      <rect x="-2.6" y="-13.2" width="5.2" height="6" rx="1.2" transform="rotate(90)" />
      <rect x="-2.6" y="-13.2" width="5.2" height="6" rx="1.2" transform="rotate(135)" />
      <rect x="-2.6" y="-13.2" width="5.2" height="6" rx="1.2" transform="rotate(180)" />
      <rect x="-2.6" y="-13.2" width="5.2" height="6" rx="1.2" transform="rotate(225)" />
      <rect x="-2.6" y="-13.2" width="5.2" height="6" rx="1.2" transform="rotate(270)" />
      <rect x="-2.6" y="-13.2" width="5.2" height="6" rx="1.2" transform="rotate(315)" />
      <circle r="9" />
    </g>
    <circle r="3.5" fill="#20283a" />
  </g>
</svg>
