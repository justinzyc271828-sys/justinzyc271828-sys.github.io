---
// 阅读页：左侧目录(带阅读进度) + 正文 + 推荐 + 订阅。正文由各文章页通过 <slot/> 传入。
import BaseLayout from './BaseLayout.astro';
import Subscribe from '../components/Subscribe.astro';
import { theme, readingTime, ymd } from '../lib/themes.js';

const { post, headings = [], related = [], sectionKey } = Astro.props;
const t = theme(sectionKey);
const toc = headings.filter((h) => h.depth === 2);
const mins = readingTime(post.body);
const sectionName = { de: '德语语法笔记', fiction: '小说 / 写作', ai: 'AI 使用体验' }[sectionKey] || sectionKey;
---

<BaseLayout title={post.data.title + ' · Grenzgang'} description={post.data.summary} active={sectionKey}>
  <div class="read-grid">

    <aside class="toc">
      <div class="toc-head"><span class="l">目录 / INDEX</span><span class="pct" id="read-pct">0%</span></div>
      <div class="toc-wrap" id="toc-wrap">
        <div class="toc-track"></div>
        <div class="toc-fill" id="read-fill"></div>
        <div class="toc-tip" id="read-tip"></div>
        <div class="toc-links">
          {toc.map((h) => (
            <a class="toc-link" href={`#${h.slug}`} data-toc={h.slug}><span class="tdot"></span>{h.text}</a>
          ))}
          {toc.length === 0 && <span class="toc-link" style="color:#aab193;">（无小标题）</span>}
        </div>
      </div>
    </aside>

    <article>
      <div class="breadcrumb"><span>首页</span><span class="slash">/</span><span style={`color:${t.dot};`}>{sectionName}</span></div>
      <span class="article-tag" style={`color:${t.tagText}; background:${t.tagBg};`}><span style={`width:6px;height:6px;border-radius:50%;background:${t.dot};`}></span>{sectionName}</span>
      <h1 class="article-title">{post.data.title}</h1>
      {post.data.summary && <div class="article-sub">{post.data.summary}</div>}
      <div class="article-meta">
        <span class="av">G</span>
        <div style="flex:1;">
          <div class="who">主理人</div>
          <div class="sub">{ymd(post.data.date)} · {mins} MIN 阅读</div>
        </div>
      </div>

      <div class="article-fig">
        <div class="grid"></div>
        <div class="glow"></div>
        <span class="sprout"></span>
        <span class="cap">FIG.01 / 封面占位</span>
      </div>

      <div class="prose">
        <slot />
      </div>

      <div class="eof"><span class="sq"></span><span class="rule"></span><span class="lbl">EOF</span></div>

      <div class="author-card">
        <span class="av">G</span>
        <div style="flex:1;">
          <div class="n">Grenzgang · 主理人</div>
          <div class="b">在柏林学德语、写小说、和机器打交道。一个人的三条写作线。</div>
        </div>
      </div>
    </article>

    <div></div>
  </div>

  {related.length > 0 && (
    <Fragment>
      <div class="sec-head">
        <span class="sec-num">→</span>
        <span class="sec-title">继续读</span>
        <span class="sec-en">/ NEXT</span>
        <span class="sec-rule"></span>
      </div>
      <div class="related-cards">
        {related.map((p) => {
          const rt = theme(p.collection);
          return (
            <a class="related-card" href={`/${p.collection}/${p.id}`}>
              <div class="glow" style={`position:absolute; top:-30px; right:-30px; width:110px; height:110px; border-radius:50%; background:radial-gradient(circle, ${rt.tagBg}, transparent 70%);`}></div>
              <span class="tag" style={`color:${rt.tagText}; background:${rt.tagBg};`}>{rt.label}</span>
              <div class="t">{p.data.title}</div>
              {p.data.summary && <div class="d">{p.data.summary}</div>}
              <div class="m">{readingTime(p.body)} MIN →</div>
            </a>
          );
        })}
      </div>
    </Fragment>
  )}

  <Subscribe heading="喜欢这篇？订阅慢读信" text="两周一封，德语、故事与 AI 的长文。" />
</BaseLayout>

<script is:inline>
  (function () {
    const wrap = document.getElementById('toc-wrap');
    const fill = document.getElementById('read-fill');
    const tip = document.getElementById('read-tip');
    const pct = document.getElementById('read-pct');
    if (!wrap) return;
    const links = Array.from(document.querySelectorAll('[data-toc]'));
    function onScroll() {
      const doc = document.documentElement;
      const top = window.scrollY || doc.scrollTop || 0;
      const h = doc.scrollHeight - doc.clientHeight;
      const p = h > 0 ? Math.min(1, Math.max(0, top / h)) : 0;
      const trackH = Math.max(0, wrap.clientHeight - 14);
      if (fill) fill.style.height = (p * trackH).toFixed(1) + 'px';
      if (tip) tip.style.top = (7 + p * trackH).toFixed(1) + 'px';
      if (pct) pct.textContent = Math.round(p * 100) + '%';
      const fillPx = 7 + p * trackH;
      links.forEach((a, i) => {
        const center = a.offsetTop + a.offsetHeight / 2;
        const passed = i === 0 || fillPx >= center - 1;
        a.style.color = passed ? '#3a4a2c' : '';
        a.style.fontWeight = passed ? '600' : '';
        const dot = a.querySelector('.tdot');
        if (dot) { dot.style.background = passed ? '#7cc068' : ''; dot.style.borderColor = passed ? '#7cc068' : ''; }
      });
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    onScroll();
  })();
</script>
