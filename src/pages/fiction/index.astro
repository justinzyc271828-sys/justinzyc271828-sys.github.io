---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionArchive from '../../components/SectionArchive.astro';
import Subscribe from '../../components/Subscribe.astro';
const posts = await getCollection('fiction');
---

<BaseLayout title="小说 / 写作 · 心智边界" active="fiction">
  <SectionArchive sectionKey="fiction" title="小说 / 写作" subtitle="半成品、废稿与偶尔成形的短篇，都留在这里。" posts={posts} />
  <Subscribe />
</BaseLayout>
